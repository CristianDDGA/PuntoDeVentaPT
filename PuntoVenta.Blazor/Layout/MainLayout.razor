@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using PuntoVenta.Blazor.Services
@inject NavigationManager Navigation
@inject AuthSessionService AuthSessionService
@implements IDisposable

<div class="layout-wrapper">

    <aside class="sidebar">
        <!-- Header / Logo -->
        <div class="sidebar-header brand">
            <div>
                <h2 class="logo">Punto de Venta</h2>
                <p class="logo-subtitle">Sistema POS</p>
            </div>
        </div>

        <!-- User Box -->
        <AuthorizeView>
            <Authorized Context="authState">
                <div class="user-box" aria-label="Usuario actual">
                    <strong>@authState.User.Identity?.Name</strong><br>
                    <small>@authState.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</small>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="user-box" aria-label="Usuario actual">
                    <strong>Sesión no iniciada</strong><br>
                    <small>Acceso requerido</small>
                </div>
            </NotAuthorized>
        </AuthorizeView>

        <!-- Navigation Menu -->
        <nav class="sidebar-nav menu" aria-label="Menú principal">
            <p class="nav-caption">Principal</p>
            
            <NavLink class="menu-item" href="/" Match="NavLinkMatch.All">
                <span class="menu-icon" aria-hidden="true">
                    <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z"></path></svg>
                </span>
                <span class="menu-label">Dashboard</span>
            </NavLink>
            
            <NavLink class="menu-item" href="/nueva-venta">
                <span class="menu-icon" aria-hidden="true">
                    <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 13h6m-3-3v6m5 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                </span>
                <span class="menu-label">Nueva Venta</span>
            </NavLink>
            
            <NavLink class="menu-item" href="/historial">
                <span class="menu-icon" aria-hidden="true">
                    <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path></svg>
                </span>
                <span class="menu-label">Historial</span>
            </NavLink>

            <NavLink class="menu-item" href="/clientes">
                <span class="menu-icon" aria-hidden="true">
                    <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                </span>
                <span class="menu-label">Clientes</span>
            </NavLink>

            <NavLink class="menu-item" href="/productos">
                <span class="menu-icon" aria-hidden="true">
                    <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path></svg>
                </span>
                <span class="menu-label">Productos</span>
            </NavLink>

            <AuthorizeView Roles="Admin">
                <Authorized>
                    <NavLink class="menu-item" href="/users">
                        <span class="menu-icon" aria-hidden="true">
                            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                        </span>
                        <span class="menu-label">Usuarios</span>
                    </NavLink>
                </Authorized>
            </AuthorizeView>
        </nav>

        <!-- Footer / Clock -->
        <div class="sidebar-footer" aria-label="Acciones de usuario">
            <button class="footer-btn" type="button" aria-label="Perfil (visual)">
                <span class="footer-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="8" r="4"></circle>
                        <path d="M6 21v-2a4 4 0 014-4h4a4 4 0 014 4v2"></path>
                    </svg>
                </span>
                <span class="footer-label">Perfil</span>
            </button>

            <button class="footer-btn footer-btn-logout" type="button" aria-label="Cerrar sesión" @onclick="LogoutAsync">
                <span class="footer-icon" aria-hidden="true">
                    <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                        <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"></path>
                        <polyline points="16 17 21 12 16 7"></polyline>
                        <line x1="21" y1="12" x2="9" y2="12"></line>
                    </svg>
                </span>
                <span class="footer-label">Salir</span>
            </button>
            <div style="margin-top:var(--spacing-md); text-align:center; font-variant-numeric:tabular-nums; color:var(--color-text-muted); font-size:var(--font-size-xs);">
                @_currentDateTime
            </div>
        </div>
    </aside>

    <main class="main-content">
        <div class="page-content">
            <ErrorBoundary>
                <ChildContent>
                    @Body
                </ChildContent>
                <ErrorContent Context="ex">
                    <div class="alert alert--error" style="white-space: pre-wrap; font-family: monospace;">
                        <strong>Se produjo un error no controlado:</strong>
                        <br/>
                        @ex.Message
                        <br/>
                        @ex.StackTrace
                    </div>
                </ErrorContent>
            </ErrorBoundary>
        </div>
    </main>

</div>

@code {
    private string _currentDateTime = string.Empty;
    private Timer? _clockTimer;

    protected override void OnInitialized()
    {
        UpdateClock();
        _clockTimer = new Timer(_ =>
        {
            UpdateClock();
            InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    private void UpdateClock()
        => _currentDateTime = DateTime.Now.ToString("dd/MM/yyyy  HH:mm:ss");

    private async Task LogoutAsync()
    {
        await AuthSessionService.LogoutAsync();
        Navigation.NavigateTo("/login", true);
    }

    public void Dispose()
        => _clockTimer?.Dispose();
}
