@if (_isVisible)
{
    <div class="modal-overlay confirm-modal-overlay" @onclick="OnCancel">
        <div class="modal-box confirm-modal-box" @onclick:stopPropagation>

            <div class="confirm-modal-icon">
                <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
                </svg>
            </div>

            <div class="confirm-modal-content">
                <h3 class="confirm-modal-title">@Title</h3>
                <p class="confirm-modal-message">@Message</p>
            </div>

            <div class="confirm-modal-actions">
                <button class="btn btn--ghost" @onclick="OnCancel">Cancelar</button>
                <button class="btn btn--danger-solid" @onclick="OnConfirm">@ConfirmText</button>
            </div>

        </div>
    </div>
}

@code {
    [Parameter] public string Title       { get; set; } = "¿Confirmar acción?";
    [Parameter] public string Message     { get; set; } = "Esta acción no se puede deshacer.";
    [Parameter] public string ConfirmText { get; set; } = "Confirmar";

    private bool _isVisible = false;
    private TaskCompletionSource<bool>? _tcs;

    /// <summary>Shows the modal and returns true if user confirms, false if cancelled.</summary>
    public Task<bool> ShowAsync(string message, string title = "¿Confirmar acción?", string confirmText = "Confirmar")
    {
        Title       = title;
        Message     = message;
        ConfirmText = confirmText;
        _isVisible  = true;
        _tcs        = new TaskCompletionSource<bool>();
        StateHasChanged();
        return _tcs.Task;
    }

    private void OnConfirm()
    {
        _isVisible = false;
        _tcs?.SetResult(true);
    }

    private void OnCancel()
    {
        _isVisible = false;
        _tcs?.SetResult(false);
    }
}
